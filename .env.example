# Copy to .env and fill in. Never commit .env — it's gitignored.

# ─── Django ────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ──────────────────────────────────────────
# Falls back to sqlite:///db.sqlite3 if unset — only acceptable for local
DATABASE_URL=
DB_CONN_MAX_AGE=60

# ─── Redis / Celery ────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=

# Backs CHANNEL_LAYERS (apps.notifications real-time push over WebSocket).
# Falls back to REDIS_URL if unset.
CHANNEL_REDIS_URL=

# ─── JWT ───────────────────────────────────────────────
JWT_SIGNING_KEY=
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── Social Auth ────────────────────────────────────────
# Comma-separated Google OAuth client IDs (web + mobile) accepted as the
# `aud` claim on a Google ID token. See apps/accounts/services/google_auth_services.py.
GOOGLE_OAUTH_CLIENT_IDS=

# ─── CORS ──────────────────────────────────────────────
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ─── Observability ─────────────────────────────────────
LOG_FORMAT=console
LOG_LEVEL=INFO

# ─── Local dev only (config/settings/local.py) ─────────
SITE_URL=http://localhost:8000

# ─── Staging / Production only (config/settings/staging.py) ───
# Required (no default) once DJANGO_SETTINGS_MODULE=config.settings.staging
# or .production — the app will refuse to boot without these.
DJANGO_SECURE_SSL_REDIRECT=True
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_DEFAULT_FROM_EMAIL=
