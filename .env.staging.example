# ─── Postgres ─────
POSTGRES_DB=buddy_db
POSTGRES_USER=buddy
POSTGRES_PASSWORD=

# ─── Django ──────────────────────────────────────────
DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# No TLS termination in this compose stack (nginx serves plain HTTP) — set
# True once a real cert/TLS-terminating LB sits in front, or every request
# will redirect-loop against X-Forwarded-Proto: http.
DJANGO_SECURE_SSL_REDIRECT=False

JWT_SIGNING_KEY=

# ─── Social Auth ─────────────────────────────────────
GOOGLE_OAUTH_CLIENT_IDS=

# ─── CORS ────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ─── Email (required — config/settings/staging.py has no defaults) ──
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_DEFAULT_FROM_EMAIL=

# ─── Observability ───────────────────────────────────
LOG_FORMAT=json
LOG_LEVEL=INFO

# ─── Nginx ───────────────────────────────────────────
HTTP_PORT=80
